# Halium minimal fstab for mt6765

/dev/block/platform/bootdevice/by-name/persist   /mnt/vendor/persist   ext4  defaults  wait
/dev/block/platform/bootdevice/by-name/nvdata    /mnt/vendor/nvdata    ext4  defaults  wait
/dev/block/platform/bootdevice/by-name/protect1  /mnt/vendor/protect_f ext4 defaults  wait
/dev/block/platform/bootdevice/by-name/protect2  /mnt/vendor/protect_s ext4 defaults  wait
/system  /system  ext4  ro,barrier=1  wait
/vendor  /vendor  ext4  ro,barrier=1  wait
/data    /data    ext4  nosuid,nodev,noatime  wait
/cache   /cache   ext4  nosuid,nodev  wait


# endhalium
