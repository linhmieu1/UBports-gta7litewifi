<?xml version="1.0" encoding="UTF-8"?>
<repowerd>
    <backlight_sysfs_path>/sys/class/leds/lcd-backlight/brightness</backlight_sysfs_path>

    <backlight_max_value>255</backlight_max_value>

    <input_devices>
        <input_device>
            <name>mtk-kpd</name>
            <wakeup>true</wakeup>
        </input_device>
        <input_device>
            <name>mtk-pmic-keys</name>
            <wakeup>true</wakeup>
        </input_device>
        <input_device>
            <name>sec_touchscreen</name>
            <wakeup>true</wakeup>
        </input_device>
    </input_devices>
</repowerd>
